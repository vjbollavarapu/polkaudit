# PolkAudit hybrid deployment — environment reference
# Copy values to the right place; never commit real secrets.
#
# Architecture: Oracle VM (indexer) + GCP Cloud Run (backend, dashboard) + Neon (DB)

# =============================================================================
# Neon (shared by backend + indexer)
# =============================================================================
# GCP Secret Manager: polkaudit-database-url
# Oracle VM:         /etc/polkaudit/indexer.env

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# =============================================================================
# GCP Cloud Run — backend (Secret Manager + cloudbuild)
# =============================================================================
# Secret: polkaudit-api-key
API_KEY=your-production-api-key
LOG_LEVEL=INFO

# =============================================================================
# GCP Cloud Build trigger substitutions
# =============================================================================
# _REGION=asia-southeast1
# _API_KEY=your-production-api-key   # must match polkaudit-api-key secret

# =============================================================================
# Oracle VM — /etc/polkaudit/indexer.env (see deploy/oracle/indexer.env.example)
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://...?sslmode=require
# SUBSTRATE_RPC_URL=wss://rpc.polkadot.io
# METRICS_PORT=8001
# INDEXER_START_BLOCK=31387000
# INDEXER_CATCHUP_WINDOW=2000

# =============================================================================
# After deploy — verify from laptop
# =============================================================================
# export BACKEND_URL=https://polkaudit-backend-xxxxx.run.app
# export DASHBOARD_URL=https://polkaudit-dashboard-xxxxx.run.app
# export API_KEY=your-production-api-key
# ./scripts/hybrid-verify.sh
