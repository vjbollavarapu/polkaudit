# PolkAudit indexer — hybrid deployment (Oracle VM)
# Copy to /etc/polkaudit/indexer.env on the VM (chmod 600).
# setup-indexer.sh creates this file on first run.

# Same Neon database as GCP backend (Secret Manager polkaudit-database-url)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# Polkadot RPC (use dedicated provider for production)
SUBSTRATE_RPC_URL=wss://rpc.polkadot.io

LOG_LEVEL=INFO
METRICS_PORT=8001
RETRY_DELAY_SECONDS=2

# Demo: skip millions of blocks on empty DB (update to recent height periodically)
INDEXER_START_BLOCK=31387000
INDEXER_CATCHUP_WINDOW=2000
